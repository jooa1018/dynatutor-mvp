      "expected_canonical_facts": {
        "system_type": "constant_acceleration_1d",
        "subtype": null,
        "known_values": {
          "v0": 0,
          "a": 3,
          "t": 4
        }
      },
      "expected_route": "constant_acceleration_1d",
      "expected_requested_outputs": [
        "final_velocity"
      ],
      "expected_answers": [
        {
          "selector": "primary",
          "numeric": 12,
          "unit": "m/s"
        }
