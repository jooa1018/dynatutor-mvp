# Required for authenticated personal/cloud deployments.
DYNATUTOR_ACCESS_TOKEN=replace-with-a-long-random-token
DYNATUTOR_CORS_ORIGINS=http://localhost:3000
DYNATUTOR_DB=./dynatutor_records.sqlite
DYNATUTOR_PUBLIC_DOCS=false

# Optional guarded LLM explanation layer.
LLM_ENABLED=auto
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=
